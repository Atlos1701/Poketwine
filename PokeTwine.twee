:: TurnOrder {"position":"1825,1400","size":"100,100"}
(if:($PKindex's ($CurrentPokemon's Species)'s Stats's 6)>=($PKindex's ($EnemySpecies)'s Stats's 6))[(set:$FirstTurn to "Player")(go-to:"PlayerMoveMath")](else:)[(set:$FirstTurn to "Enemy")(go-to:"EnemyAI")]


:: Victory {"position":"1825,1525","size":"100,100"}
You won! (set:_lv to $CurrentPokemon's lv)

(print:$CurrentPokemon's Species) got (print: (floor:($PKindex's $EnemySpecies's BaseXP*$EnemyLevel)/7)) xp!

(if:$CurrentPokemon's xp >= (floor:((6/5)*_lv*_lv*_lv)-(15*_lv*_lv)+(100*_lv)-140))[(set:$CurrentPokemon's lv to it + 1)(print: $CurrentPokemon's Species) leveled up to (print:$CurrentPokemon's lv)!<br>]
(link-goto:"Next", $Return)

(set: $CurrentPokemon's xp to it + ($PKindex's $EnemySpecies's BaseXP*$EnemyLevel)/7)
(set: $Party's $CurrentPokemonReturn to $CurrentPokemon)


