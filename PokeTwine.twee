:: CatchLoop {"position":"2200,1525","size":"100,100"}
(set:$Timer to it - 1)Wiggle... (set:_roll to (random:100))(if:_roll >70)[(set:$next to "Caught")](else:)[(set:$next to "CatchLoop")(if:$Timer is 0)[(set:$next to "EnemyAI")(set:$FirstTurn to "Player")]]

(link-goto:"Next", $next)



:: Caught {"position":"2200,1650","size":"100,100"}
You caught $EnemySpecies! (set:_lv to $EnemyLevel)(if:(floor:((6/5)*_lv*_lv*_lv)-(15*_lv*_lv)+(100*_lv)-140)>=0)[(set:$EnemyXp to (floor:((6/5)*_lv*_lv*_lv)-(15*_lv*_lv)+(100*_lv)-140))](else:)[(set:$EnemyXp to 0)]

(if: length of $Party < 6)[It was added to your party!](else:)[It was sent to your box!]
(if:$EnemySpecies is not in $Pokedex)[(set:$Pokedex to it + (a:$EnemySpecies))<br><img src="Images\PokyDex.png">(text-colour:red)[ : POKEDEX UPDATED]
(link-goto:$EnemySpecies)(set:$MenuReturn to $Return)<br>]
(link-goto:"Next", $Return)

(set: $Party's $CurrentPokemonReturn to $CurrentPokemon)

(set: _newPK to (dm: 
	"Species", $EnemySpecies,
    "lv", $EnemyLevel,
    "hp", $EnemyHP,
    "png", $PKindex's $EnemySpecies's png,
    "xp",  $EnemyXp
))

(if:  (length of $Party) < 6)[(set: $Party to $Party + (a: _newPK))]
(else:)[(set: $box to it + (a: _newPK))]




