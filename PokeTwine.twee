:: StoryStylesheet [stylesheet]
tw-story{
  font-family: "Noto Sans", sans-serif !important;
  background-color:#0f111a
}

tw-passage{
  background-color: #131621;
  border: 5px solid #ff0000;
  padding: 20px
}

tw-link, a{
  color: #66b3ff !important;
  line-height: 1.2
}

tw-link:hover, a:hover{
  background-color: #0f111a
}

tw-sidebar{
  display: none
}