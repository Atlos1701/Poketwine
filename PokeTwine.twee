:: EnemyAI {"position":"2075,1400","size":"100,100"}
(set: _maxpoints to 0)(for: each _move, ...$PKindex's $EnemySpecies's Moves)[(set:_points to 0)
	(if: ($ENdefBonus or $ENattackBonus or $ENspeedBonus <10) and (($Aindex's _move's 5) is 5 or ($Aindex's _move's 6) is 5 or ($Aindex's _move's 7) is 5))[(set:_points to it + 8)]
    (if: $Aindex's _move's 3 > 0)[(set:_points to it + 10)]
    (if: $EnemyHP < (0.2*(floor:((($PKindex's ($EnemySpecies)'s Stats's 1)*$EnemyLevel)/50)+10)) and $Aindex's _move's 4 > 0)[(set:_points to it + 8)]
    (set:_points to it + (random: -5, 5))
	(if:_points >= _maxpoints)[(set:_maxpoints to _points)(set:$SelectedMove to _move)]
]
(go-to:"EnemyMoveMath")



:: EnemyMoveMath {"position":"1950,1525","size":"100,100"}
Enemy used $SelectedMove! (if:$Aindex's $SelectedMove's 2 is "physical")[(set: $userAttack to ($PKindex's ($EnemySpecies)'s Stats's 4)+$ENattackBonus)(set:$enemyDefense to ($PKindex's ($CurrentPokemon's Species)'s Stats's 4))](else:)[((set: $userAttack to ($PKindex's ($EnemySpecies)'s Stats's 5)+$ENattackBonus)(set:$enemyDefense to ($PKindex's ($CurrentPokemon's Species)'s Stats's 5))]\
(set:$Effective to 1)
(if:$PKindex's ($CurrentPokemon's Species)'s Types's 1 is in $Tindex's ($Aindex's $SelectedMove's 1))[
(set:$Effective to ($Tindex's ($Aindex's $SelectedMove's 1)'s ($PKindex's ($CurrentPokemon's Species)'s Types's 1)))\
](if: length of $PKindex's ($CurrentPokemon's Species)'s Types >1)[(if:$PKindex's ($CurrentPokemon's Species)'s Types's 2 is in $Tindex's ($Aindex's $SelectedMove's 1))[
(set:$Effective to it *($Tindex's ($Aindex's $SelectedMove's 1)'s ($PKindex's ($CurrentPokemon's Species)'s Types's 2)))]]\

